// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
  // provider = "mysql"
  // url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Questionnaire {
  id                       BigInt                @id @default(autoincrement()) @map("id")
  title                    String?               @db.VarChar(255)
  description              String?               @db.Text
  ctaText                  String?               @map("cta_text") @db.VarChar(255)
  createdAt                DateTime              @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime              @map("updated_at") @db.Timestamp(6)
  overlayTextWidthDesktop  Int?                  @map("overlay_text_width_desktop")
  overlayTextWidth         Int?                  @map("overlay_text_width")
  disclaimer               String?               @db.Text
  sections                 QuestionnaireSection[]

  @@map("questionairs")
}

model QuestionnaireSection {
  id                      BigInt             @id @default(autoincrement()) @map("id")
  title                   String?            @db.VarChar(255)
  description             String?            @db.Text
  ctaText                 String?            @map("cta_text") @db.VarChar(255)
  questionnaireId         BigInt             @map("questionair_id")
  createdAt               DateTime           @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime           @map("updated_at") @db.Timestamp(6)
  overlayTextWidthDesktop Int?               @map("overlay_text_width_desktop")
  overlayTextWidth        Int?               @map("overlay_text_width")
  disclaimer              String?            @db.Text
  questionnaire           Questionnaire      @relation(fields: [questionnaireId], references: [id])
  sectionQuestions        SectionQuestion[]

  @@map("questionair_sections")
}

model SectionQuestion {
  id                      BigInt              @id @default(autoincrement()) @map("id")
  description             String?             @db.Text
  shareMore               String?             @map("share_more") @db.Text
  questionnaireSectionId  BigInt              @map("questionair_section_id")
  createdAt               DateTime            @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime            @map("updated_at") @db.Timestamp(6)
  overlayTextWidthDesktop Int?                @map("overlay_text_width_desktop")
  overlayTextWidth        Int?                @map("overlay_text_width")
  questionnaireSection    QuestionnaireSection @relation(fields: [questionnaireSectionId], references: [id])
  questions               Question[]

  @@map("section_questions")
}

model Question {
  id                BigInt          @id @default(autoincrement()) @map("id")
  questionText      String?         @map("question_text") @db.VarChar(255)
  options           String?         @db.Text
  sectionQuestionId BigInt          @map("section_question_id")
  createdAt         DateTime        @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime        @map("updated_at") @db.Timestamp(6)
  ctaText           String?         @map("cta_text") @db.VarChar(255)
  sectionQuestion   SectionQuestion @relation(fields: [sectionQuestionId], references: [id])
  responses         Response[]

  @@map("questions")
}

model LegacyAccount {
  id                 Int        @id @default(autoincrement()) @map("id")
  salt               String?    @db.VarChar(255)
  name               String?    @db.VarChar(255)
  email              String?    @db.VarChar(255)
  hashedPassword     String?    @map("hashed_password") @db.VarChar(255)
  createdAt          DateTime   @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime   @map("updated_at") @db.Timestamp(6)
  vault              String?    @db.VarChar(255)
  firstName          String?    @map("first_name") @db.VarChar(255)
  lastName           String?    @map("last_name") @db.VarChar(255)
  encryptedPassword  String     @map("encrypted_password") @db.VarChar(255)
  resetPasswordToken String?    @map("reset_password_token") @db.VarChar(255)
  resetPasswordSentAt DateTime? @map("reset_password_sent_at")
  rememberCreatedAt   DateTime? @map("remember_created_at")
  responses           Response[]

  @@map("accounts")
}

model Response {
  id         BigInt        @id @default(autoincrement()) @map("id")
  accountId  Int           @map("account_id")
  questionId BigInt        @map("question_id")
  response   String?       @db.VarChar(255)
  createdAt  DateTime      @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime      @map("updated_at") @db.Timestamp(6)
  shareMore  String?       @map("share_more") @db.Text
  account    LegacyAccount @relation(fields: [accountId], references: [id])
  question   Question      @relation(fields: [questionId], references: [id])

  @@index([questionId], map: "index_responses_on_question_id")
  @@map("responses")
}
